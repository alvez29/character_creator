[sub_resource type="Shader" id="Shader_6iv14"]
code = "shader_type spatial;

// Parámetros de estiramiento
uniform float stretch_factor_y : hint_range(0.0, 0.01) = 0.0007;
uniform float stretch_factor_x : hint_range(0.0, 0.01) = 0.0004;
uniform float max_stretch : hint_range(1.0, 5.0) = 2.0;
uniform float min_stretch : hint_range(0.1, 1.0) = 0.5;

// Opciones de estiramiento direccional
uniform bool use_directional_stretch = false;
uniform float directional_blend : hint_range(0.0, 1.0) = 0.5;

// Velocidad del objeto (actualizada desde el script)
uniform vec3 velocity = vec3(0.0);

void vertex() {
	float velocity_magnitude = length(velocity);
	
	if (velocity_magnitude > 0.001) {
		if (use_directional_stretch && velocity_magnitude > 0.01) {
			// Modo direccional: estira en la dirección del movimiento
			vec3 velocity_dir = normalize(velocity);
			
			// Convertimos la velocidad a espacio local del objeto
			vec3 local_vel = (MODEL_MATRIX * vec4(velocity_dir, 0.0)).xyz;
			local_vel = normalize(local_vel);
			
			// Calculamos stretch direccional
			float sy = 1.0 + velocity_magnitude * stretch_factor_y;
			float sx = 1.0 - velocity_magnitude * stretch_factor_x;
			
			sy = clamp(sy, min_stretch, max_stretch);
			sx = clamp(sx, min_stretch, max_stretch);
			
			// Aplicamos stretch en la dirección del movimiento
			float stretch_along = sy;
			float stretch_perpendicular = sx;
			
			// Proyectamos el vértice en la dirección de velocidad
			float projection = dot(VERTEX, local_vel);
			vec3 parallel = local_vel * projection;
			vec3 perpendicular = VERTEX - parallel;
			
			// Mezclamos entre stretch clásico y direccional
			vec3 classic_stretch = vec3(sx, sy, sx);
			vec3 directional_vertex = parallel * stretch_along + perpendicular * stretch_perpendicular;
			vec3 classic_vertex = VERTEX * classic_stretch;
			
			VERTEX = mix(classic_vertex, directional_vertex, directional_blend);
			
		} else {
			// Modo clásico: estira en Y, comprime en X/Z
			float sy = 1.0 + velocity_magnitude * stretch_factor_y;
			float sx = 1.0 - velocity_magnitude * stretch_factor_x;
			
			sy = clamp(sy, min_stretch, max_stretch);
			sx = clamp(sx, min_stretch, max_stretch);
			
			VERTEX.x *= sx;
			VERTEX.y *= sy;
			VERTEX.z *= sx;
		}
	}
}

void fragment() {
	ALBEDO = vec3(1.0);
}
"

